name: K8s Runner Load Test

on:
  workflow_dispatch:

jobs:
  load-test:
    runs-on: [self-hosted, eks-runner]

    strategy:
      matrix:
        load: [small, medium, large]

    steps:
      - name: Show load type
        run: echo "Running ${{ matrix.load }}"

      - name: Run load safely
        run: |
          if [ "${{ matrix.load }}" = "small" ]; then
            dd if=/dev/zero of=/tmp/test bs=1M count=100
          elif [ "${{ matrix.load }}" = "medium" ]; then
            dd if=/dev/zero of=/tmp/test bs=1M count=300
          else
            dd if=/dev/zero of=/tmp/test bs=1M count=600
          fi

      - name: CPU stress
        run: |
          timeout 10s yes > /dev/null || true

      - name: Print resources
        run: |
          nproc
          free -h
